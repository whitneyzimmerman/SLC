    <script>
        function getArticleTextWithLinks() {
            const content = document.getElementById('article-content').cloneNode(true);
            
            // Convert links to "text (url)" format
            const links = content.querySelectorAll('a');
            links.forEach(link => {
                const url = link.href;
                const text = link.textContent;
                // Only add URL if it's different from the text (not already a bare URL)
                if (url && !text.includes(url)) {
                    link.replaceWith(`${text} (${url})`);
                }
            });
            
            // Get text content, preserving paragraph breaks
            const paragraphs = content.querySelectorAll('p, h1, h2, h3, h4, li');
            let text = '';
            
            if (paragraphs.length > 0) {
                paragraphs.forEach(p => {
                    text += p.textContent.trim() + '\n\n';
                });
            } else {
                text = content.textContent;
            }
            
            return text.trim();
        }
        
        function copyAndOpen(service) {
            const articleText = getArticleTextWithLinks();
            const prompt = `Please provide a comprehensive summary of the following article. Preserve the key insights and main arguments. If there are URLs in the text, you may access them for additional context if needed.\n\n---\n\n${articleText}`;
            
            // Copy to clipboard
            navigator.clipboard.writeText(prompt).then(() => {
                // Show success message
                const status = document.getElementById('status');
                status.className = 'status success';
                status.textContent = '✓ Copied to clipboard! Paste in the new tab.';
                
                // Open the appropriate service
                const urls = {
                    claude: 'https://claude.ai/new',
                    chatgpt: 'https://chat.openai.com/',
                    gemini: 'https://gemini.google.com/app'
                };
                
                window.open(urls[service], '_blank');
            }).catch(err => {
                alert('Could not copy to clipboard. Please try again.');
                console.error(err);
            });
        }
